@model ThesisDB.Models.PaginatedList<ThesisDB.Models.Thesis>

@{
    ViewData["Title"] = "Themen-Übersicht";
}

<h1 class="mb-4">@ViewData["Title"]</h1>

<div class="list-group shadow-sm" id="thesis-list-group">
    <!-- 1. ListGroup-Item: Header mit Create-Button und Suche -->
    <div class="list-group-item bg-light d-flex justify-content-between align-items-center p-3">
        <div>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i> Neu anlegen
            </a>
        </div>
        <div style="width: 400px;">
            <div class="input-group">
                <input type="text" id="searchInput" class="form-control" placeholder="Suchen in Titel, Name..." value="@ViewData["CurrentFilter"]">
                <button class="btn btn-primary" type="button" onclick="loadPage(1)" title="Suchen">
                    <i class="bi bi-search"></i>
                </button>
                <button class="btn btn-secondary" type="button" onclick="resetSearch()" title="Filter zurücksetzen">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Container für Tabelle und Pagination (wird über AJAX neu geladen) -->
    <div id="dynamic-content">
        <partial name="_ThesisListGroupPartial" model="Model" />
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("searchInput").addEventListener("keypress", function(event) {
            if (event.key === "Enter") {
                event.preventDefault();
                loadPage(1);
            }
        });

        function resetSearch() {
            document.getElementById("searchInput").value = "";
            loadPage(1);
        }

        function loadPage(pageNumber) {
            const searchString = document.getElementById("searchInput").value;
            const pageSize = document.getElementById("pageSizeSelect") ? document.getElementById("pageSizeSelect").value : @ViewData["PageSize"];
            
            const url = `@Url.Action("Index")?searchString=${encodeURIComponent(searchString)}&pageNumber=${pageNumber}&pageSize=${pageSize}`;
            
            fetch(url, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                document.getElementById('dynamic-content').innerHTML = html;
            })
            .catch(error => console.error('Error fetching table data:', error));
        }
    </script>
}
